// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User model for authentication
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // For email/password auth (optional, can be null for OAuth users)
  credits       Int       @default(50) // Free users start with 50 credits
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  transactions CreditTransaction[]
}

// Subscription plans
enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// Credit transaction model to track all credit usage
model CreditTransaction {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  userId      String          @db.ObjectId
  amount      Int // Negative for deductions, positive for additions
  type        TransactionType
  description String
  metadata    Json? // Store additional info like feature used, image generated, etc.
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Transaction types for different features
enum TransactionType {
  PHOTO_GENERATION // 25 credits - Fashion Try-on, Product Model
  TEXT_PROMPT // 10 credits - Prompt to Image, Image to Prompt
  PHOTO_ENHANCEMENT // 15 credits - Photography AI Enhancement & Style Presets
  CREDIT_PURCHASE // Credit purchase (positive amount)
  SIGNUP_BONUS // Initial signup bonus
  REFUND // Refund credits
}

// Account model for OAuth providers
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Session model (optional - we'll use JWT tokens stored in cookies instead)
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Verification token model for email verification
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Gallery Image model to store user's generated images
model GalleryImage {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  title     String
  imageUrl  String
  type      GalleryImageType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, createdAt])
}

// Gallery image types
enum GalleryImageType {
  FASHION_TRYON
  PRODUCT_MODEL
  PROMPT_TO_IMAGE
  AI_PHOTOGRAPHY
}
